# Copy to .env and fill in real values. .env is gitignored.
#
# Nothing below is required for core validation, attribution, schema diff, or
# report JSON — those use local files only.

# --- Optional: ContractGenerator LLM annotations (OpenRouter chat) ---
# Without this, generator still runs; llm_annotations are marked "skipped".
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model id on OpenRouter (default if unset: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional header OpenRouter recommends for rankings (URL of your app/site)
OPENROUTER_HTTP_REFERER=https://localhost

# --- Optional: AI extensions — embedding drift (OpenAI embeddings API) ---
# Used only when running: python contracts/ai_extensions.py --mode embedding|all
# and you have enough text samples in extractions.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
